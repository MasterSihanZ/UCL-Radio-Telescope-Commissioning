= t.iso.split(\".\")[0]\n","        az = np.median(data[\"Azimuth\"])\n","        el = np.median(data[\"Elevation\"])\n","\n","        plt.figure(figsize=(12,6))\n","        plt.plot(x1,y1, \".\", ms=4)\n","        plt.title(fname.split(\"/\")[-1])\n","        plt.xlabel(\"Az_Offset\")\n","        plt.ylabel(\"LEFT_POL\")\n","        plt.tight_layout()\n","        plt.show()\n","\n","        plt.figure(figsize=(12,6))\n","        plt.plot(x1,y1, \".\", ms=4)\n","        plt.title(fname.split(\"/\")[-1])\n","        plt.xlabel(\"Az_Offset\")\n","        plt.ylabel(\"RIGHT_POL\")\n","        plt.tight_layout()\n","        plt.show()\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"fxVhUljcz04G","executionInfo":{"status":"ok","timestamp":1776282480725,"user_tz":-60,"elapsed":4854,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"201755df-126c-4ded-e10e-e7ecd6160201"},"execution_count":124,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":[],"metadata":{"id":"vofYQp0Vpqt8"}},{"cell_type":"markdown","source":["# 0212 7 DATA SETs: 5 for SUN 2 for TAU A\n","Last 3 DATA SETs"],"metadata":{"id":"S6zPD8i1pt8M"}},{"cell_type":"code","source":["for fname in fits_files2[2:5]:\n","    with fits.open(fname) as hdul:\n","        data = hdul[1].data\n","        hdr = hdul[0].header\n","        x1 = data[\"Az_Offset\"]\n","        x2 = data[\"El_Offset\"]\n","        y1 = data[\"LEFT_POL\"]\n","        y2 = data[\"RIGHT_POL\"]\n","        t = Time(data[\"JD\"][0], format=\"jd\")\n","        time_str = t.iso.split(\".\")[0]\n","        az = np.median(data[\"Azimuth\"])\n","        el = np.median(data[\"Elevation\"])\n","\n","\n","\n","        plt.figure(figsize=(12,6))\n","        plt.plot(x2, y1, \".\", ms=4)\n","        plt.title(fname.split(\"/\")[-1])\n","        plt.xlabel(\"El_Offset\")\n","        plt.ylabel(\"LEFT_POL\")\n","        plt.tight_layout()\n","        plt.show()\n","\n","        plt.figure(figsize=(12,6))\n","        plt.plot(x2, y2, \".\", ms=4)\n","        plt.title(fname.split(\"/\")[-1])\n","        plt.xlabel(\"El_Offset\")\n","        plt.ylabel(\"RIGHT_POL\")\n","        plt.tight_layout()\n","        plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"_IsKyaEG0Bj_","executionInfo":{"status":"ok","timestamp":1776282484051,"user_tz":-60,"elapsed":3324,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"cf51eff7-0388-4c3b-84da-c31ddb99105d"},"execution_count":125,"outputs":[{"output_type":"stream","name":"stderr","text":["WARNING: File may have been truncated: actual file length (530280) is smaller than the expected size (532800) [astropy.io.fits.file]\n","WARNING:astropy:File may have been truncated: actual file length (530280) is smaller than the expected size (532800)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stderr","text":["WARNING: File may have been truncated: actual file length (409200) is smaller than the expected size (411840) [astropy.io.fits.file]\n","WARNING:astropy:File may have been truncated: actual file length (409200) is smaller than the expected size (411840)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stderr","text":["WARNING: File may have been truncated: actual file length (564120) is smaller than the expected size (564480) [astropy.io.fits.file]\n","WARNING:astropy:File may have been truncated: actual file length (564120) is smaller than the expected size (564480)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["# 0211 3 DATA Az"],"metadata":{"id":"HOrCAvxSreVg"}},{"cell_type":"code","source":[],"metadata":{"id":"0axr1aOM9CZ_","executionInfo":{"status":"ok","timestamp":1776282484052,"user_tz":-60,"elapsed":2,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":125,"outputs":[]},{"cell_type":"code","source":["import re,os\n","def name(fname):\n","    base = os.path.basename(fname)\n","    patterns = [ r\"^(\\d{8})[_-]?(\\d{6})\", r\"^(\\d{4})(\\d{2})(\\d{2})[_-]?(\\d{2})(\\d{2})(\\d{2})\"]\n","\n","    for pat in patterns:\n","        m = re.match(pat, base)\n","        if m:\n","            groups = m.groups()\n","            if len(groups) == 2:\n","                date_str, time_str = groups\n","                yr,mon,d = date_str[:4], date_str[4:6], date_str[6:8]\n","                hr,min,s = time_str[:2], time_str[2:4], time_str[4:6]\n","            elif len(groups) == 6:\n","                yr,mon,d,hr,min,s = groups\n","            else:\n","                continue\n","\n","            return f\"Observation time: {yr}-{mon}-{d} {hr}:{min}:{s}\"\n","\n","    return f\"Observation file: {base}\"\n","\n","name(fits_files1[0])\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":35},"id":"yQOrUAfIezeM","executionInfo":{"status":"ok","timestamp":1776282484054,"user_tz":-60,"elapsed":2,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"e427edec-abc6-445d-b9f9-e2237268e528"},"execution_count":126,"outputs":[{"output_type":"execute_result","data":{"text/plain":["'Observation time: 2026-02-11 13:46:39'"],"application/vnd.google.colaboratory.intrinsic+json":{"type":"string"}},"metadata":{},"execution_count":126}]},{"cell_type":"code","source":["#read files\n","def read_beam_data(fname, pol):\n","\n","    with fits.open(fname) as hdul:\n","        data=hdul[1].data\n","        hdr=hdul[0].header\n","\n","        x1 = data[\"Az_Offset\"]\n","        x2 = data[\"El_Offset\"]\n","        y1 = data[\"LEFT_POL\"]\n","        y2 = data[\"RIGHT_POL\"]\n","        az = np.median(data[\"Azimuth\"])\n","        el = np.median(data[\"Elevation\"])\n","\n","\n","    return x1,x2,y1,y2,az,el,hdr"],"metadata":{"id":"owsZEl5Eh6KQ","executionInfo":{"status":"ok","timestamp":1776282484084,"user_tz":-60,"elapsed":26,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":127,"outputs":[]},{"cell_type":"code","source":["# find the nearest data\n","def p2p_nearest(x, y, deg_start, deg_stop,k,step=1):\n","    az_g=np.arange(deg_start,deg_stop + 1e-12, step, dtype=float)\n","    p2p=np.full_like(az_g, np.nan, dtype=float)\n","    n_used=np.zeros_like(az_g, dtype=int)\n","\n","\n","    m=np.isfinite(x) & np.isfinite(y)\n","    x=np.asarray(x[m], float)\n","    y=np.asarray(y[m], float)\n","\n","    for i, az0 in enumerate(az_g):\n","        idx=np.argsort(np.abs(x-az0))\n","        k1=min(k, idx.size)\n","        if k1 == 0:\n","            continue\n","        y1=y[idx[:k1]]\n","\n","        n_used[i]=k1\n","        p2p[i]=np.max(y1)-np.min(y1)\n","\n","    return az_g, p2p, n_used"],"metadata":{"id":"J5uHlUlnnKPS","executionInfo":{"status":"ok","timestamp":1776282484087,"user_tz":-60,"elapsed":1,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":128,"outputs":[]},{"cell_type":"code","source":["def gaussian(x, A, mu, sigma, C):\n","    return C + A * np.exp(-(x - mu) ** 2 / (2.0 * sigma ** 2))\n","\n","def fit_gaussian(x, y, deg_start, deg_stop,k, step=1,fit_window=None):\n","    az_g, p2p, n_used = p2p_nearest(x, y, deg_start, deg_stop, k, step)\n","\n","    m=np.isfinite(az_g) & np.isfinite(p2p)\n","    x_fit=az_grid[m]\n","    y_fit=p2p[m]\n","\n","    C0=np.percentile(y_fit,20)#at 10%\n","    A0=np.max(y_fit)- C0\n","    mu0=x_fit[np.argmax(y_fit)]\n","\n","    half= C0+0.5*A0\n","    l = np.where(y_fit >= half)[0]\n","    if len(l) >=2:\n","        fwhm0 = x_fit[l[-1]]-x_fit[l[0]]\n","        sigma0 =max(fwhm0/2.355,1e-3)\n","    else:\n","        sigma0 = 2.0\n","\n","\n","    p0 = [A0, mu0, sigma0, C0]\n","\n","    popt, pcov = curve_fit(gaussian, x_fit, y_fit, p0=p0)\n","\n","    return x_fit, y_fit, popt, pcov, az_g, p2p, n_used"],"metadata":{"id":"g_PDTf_vK-H5","executionInfo":{"status":"ok","timestamp":1776282729325,"user_tz":-60,"elapsed":37,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":145,"outputs":[]},{"cell_type":"code","source":["def hpbw(sigma):\n","    k=2* np.sqrt(2 * np.log(2))*abs(sigma)\n","    return k\n","\n","\n","def hpbw_err(pcov):\n","    deg_err=0.5\n","    sigma_err = np.sqrt(pcov[2, 2])\n","    G_unc = 2.355 * sigma_err\n","    unc=np.sqrt(deg_err**2+G_unc**2)\n","    return unc"],"metadata":{"id":"_M1DKCwFLIYi","executionInfo":{"status":"ok","timestamp":1776282729900,"user_tz":-60,"elapsed":5,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":146,"outputs":[]},{"cell_type":"code","source":["def fit_pol(fname, pol, deg_start=-16, deg_stop=16, k=20, step=1, fit_window=(-5,9)):\n","    x1, x2, y1, y2, az, el, hdr = read_beam_data(fname, pol)\n","\n","    if pol == \"LEFT_POL\":\n","        az_g, p2p, n_used = p2p_nearest(x1, y1, deg_start, deg_stop, k, step)\n","    if pol == \"RIGHT_POL\":\n","        az_g, p2p, n_used = p2p_nearest(x1, y2, deg_start, deg_stop, k, step)\n","\n","    m=np.isfinite(az_g) & np.isfinite(p2p)\n","    x_fit=az_g[m]\n","    y_fit=p2p[m]\n","\n","    C0=np.percentile(y_fit,10)\n","    A0=np.max(y_fit)-C0\n","    mu0=x_fit[np.argmax(y_fit)]\n","\n","    half=C0+0.5*A0\n","    l=np.where(y_fit>=half)[0]\n","    if len(l)>=2:\n","        sigma0=max((x_fit[l[-1]]-x_fit[l[0]])/2.355,1e-3)\n","    else:\n","        sigma0=2.0\n","\n","    p0=[A0,mu0,sigma0,C0]\n","\n","    popt,pcov=curve_fit(gaussian, x_fit, y_fit, p0=p0, maxfev=20000)\n","    A,mu,sigma,C=popt\n","\n","    beam_hpbw=hpbw(sigma)\n","    unc=hpbw_err(pcov)\n","\n","    x_c=np.linspace(deg_start, deg_stop, 500)\n","    y_c=gaussian(x_c, *popt)\n","    return {\"pol\":pol, \"az_g\":az_g, \"p2p\":p2p, \"x_c\":x_c, \"y_c\":y_c, \"HPBW\":beam_hpbw, \"uncertainty\":unc, \"center\":mu}"],"metadata":{"id":"jL6SRhi6S2EU","executionInfo":{"status":"ok","timestamp":1776282730449,"user_tz":-60,"elapsed":3,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":147,"outputs":[]},{"cell_type":"code","source":["deg_error=0.5\n","def normalize(y):\n","    y = np.asarray(y, dtype=float)\n","\n","\n","    if np.sum(np.isfinite(y)) == 0:\n","        return y\n","\n","    ymin = np.nanmin(y)\n","    ymax = np.nanmax(y)\n","\n","    if np.isclose(ymax - ymin, 0):\n","        return np.full_like(y, np.nan)\n","    n=(y-ymin)/(ymax-ymin)#normalised function\n","    return n\n","\n","def normalize_r(r):\n","    r_norm = r.copy()\n","\n","    r_norm[\"p2p_norm\"] = normalize(r[\"p2p\"])\n","    r_norm[\"y_c_norm\"] = normalize(r[\"y_c\"])\n","    r_norm[\"az_unc\"] = np.full_like(r[\"az_g\"], deg_error, dtype=float)\n","\n","    return r_norm"],"metadata":{"id":"eMW9lj1VJIyY","executionInfo":{"status":"ok","timestamp":1776282730837,"user_tz":-60,"elapsed":2,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":148,"outputs":[]},{"cell_type":"code","source":["from scipy.optimize import curve_fit"],"metadata":{"id":"guBXPuDVKcqG","executionInfo":{"status":"ok","timestamp":1776282731295,"user_tz":-60,"elapsed":44,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":149,"outputs":[]},{"cell_type":"code","source":["for fname in fits_files1[:3]:\n","    left=normalize_r(fit_pol(fname, \"LEFT_POL\"))\n","    right=normalize_r(fit_pol(fname, \"RIGHT_POL\"))\n","    plt.figure(figsize=(12, 6))\n","\n","    fit_l, =plt.plot(left[\"x_c\"], left[\"y_c_norm\"], \"-\", lw=2,\n","                     label=f\"Left Polarization Gaussian fit (HPBW = {left['HPBW']:.2f} $\\pm${left['uncertainty']:.2f}°)\")\n","\n","    fit_r, =plt.plot(right[\"x_c\"], right[\"y_c_norm\"], \"--\", lw=2,\n","                     label=f\"Right Polarization Gaussian fit (HPBW = {right['HPBW']:.2f} $\\pm${right['uncertainty']:.2f}°)\")\n","\n","    err_l=plt.errorbar(left[\"az_g\"], left[\"p2p_norm\"], xerr=left[\"az_unc\"],fmt=\"o\", ms=5, capsize=3, elinewidth=1, label=\"Left Polarization data\")\n","    err_r=plt.errorbar(right[\"az_g\"], right[\"p2p_norm\"], xerr=right[\"az_unc\"],fmt=\"s\", ms=5, capsize=3, elinewidth=1, label=\"Right Polarization data\")\n","\n","    plt.title(\"Azimuth Beam Pattern with Gaussian Fit\\n\",fontsize=19)\n","    plt.suptitle(f\"{name(fname)}\",fontsize=16)\n","    plt.xlabel(\"Azimuth offset (deg)\",fontsize=15)\n","    plt.ylabel(\"Normalized peak-to-peak amplitude\",fontsize=15)\n","    plt.ylim(-0.05, 1.40)\n","    plt.grid(alpha=0.3)\n","\n","    handles=[fit_l, fit_r, err_l, err_r]\n","\n","    labels=[f\"Left Polarization Gaussian fit (HPBW = {left['HPBW']:.1f} $\\pm$ {left['uncertainty']:.1f}°)\",\n","            f\"Right Polarization Gaussian fit (HPBW = {right['HPBW']:.1f} $\\pm${right['uncertainty']:.1f}°)\",\n","            \"Left Polarization data\", \"Right Polarization data\"]\n","\n","\n","\n","\n","    plt.legend(handles, labels, frameon=True)\n","\n","    plt.tight_layout()\n","    plt.show()\n","    print(f\"Left Polarization Center = {left['center']:.3f} deg\\n\"\n","                f\"Right Polarization Center = {right['center']:.3f} deg\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"-Ur8mUIXJIwg","executionInfo":{"status":"ok","timestamp":1776285714581,"user_tz":-60,"elapsed":2335,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"f777bee7-0fa8-4df7-d69b-6bd91fc57fc9"},"execution_count":155,"outputs":[{"output_type":"stream","name":"stderr","text":["<>:7: SyntaxWarning: invalid escape sequence '\\p'\n","<>:10: SyntaxWarning: invalid escape sequence '\\p'\n","<>:24: SyntaxWarning: invalid escape sequence '\\p'\n","<>:25: SyntaxWarning: invalid escape sequence '\\p'\n","<>:7: SyntaxWarning: invalid escape sequence '\\p'\n","<>:10: SyntaxWarning: invalid escape sequence '\\p'\n","<>:24: SyntaxWarning: invalid escape sequence '\\p'\n","<>:25: SyntaxWarning: invalid escape sequence '\\p'\n","/tmp/ipykernel_2576/186192314.py:7: SyntaxWarning: invalid escape sequence '\\p'\n","  label=f\"Left Polarization Gaussian fit (HPBW = {left['HPBW']:.2f} $\\pm${left['uncertainty']:.2f}°)\")\n","/tmp/ipykernel_2576/186192314.py:10: SyntaxWarning: invalid escape sequence '\\p'\n","  label=f\"Right Polarization Gaussian fit (HPBW = {right['HPBW']:.2f} $\\pm${right['uncertainty']:.2f}°)\")\n","/tmp/ipykernel_2576/186192314.py:24: SyntaxWarning: invalid escape sequence '\\p'\n","  labels=[f\"Left Polarization Gaussian fit (HPBW = {left['HPBW']:.1f} $\\pm$ {left['uncertainty']:.1f}°)\",\n","/tmp/ipykernel_2576/186192314.py:25: SyntaxWarning: invalid escape sequence '\\p'\n","  f\"Right Polarization Gaussian fit (HPBW = {right['HPBW']:.1f} $\\pm${right['uncertainty']:.1f}°)\",\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Left Polarization Center = -0.756 deg\n","Right Polarization Center = -0.669 deg\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Left Polarization Center = 0.121 deg\n","Right Polarization Center = 0.226 deg\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Left Polarization Center = 0.275 deg\n","Right Polarization Center = 0.291 deg\n"]}]},{"cell_type":"code","source":["\n","def fit_pol_el(fname, pol, deg_start=-16, deg_stop=16, k=20, step=1, fit_window=(-8,8)):\n","    x1, x2, y1, y2, az, el, hdr = read_beam_data(fname, pol)\n","\n","    if pol == \"LEFT_POL\":\n","        az_g, p2p, n_used = p2p_nearest(x2, y1, deg_start, deg_stop, k, step)\n","    if pol == \"RIGHT_POL\":\n","        az_g, p2p, n_used = p2p_nearest(x2, y2, deg_start, deg_stop, k, step)\n","\n","\n","    m=np.isfinite(az_g) & np.isfinite(p2p)\n","    x_fit=az_g[m]\n","    y_fit=p2p[m]\n","\n","    C0=np.percentile(y_fit,10)\n","    A0=np.max(y_fit)-C0\n","    mu0=x_fit[np.argmax(y_fit)]\n","\n","    half=C0+0.5*A0\n","    l=np.where(y_fit>=half)[0]\n","    if len(l)>=2:\n","        sigma0=max((x_fit[l[-1]]-x_fit[l[0]])/2.355,1e-3)\n","    else:\n","        sigma0=2.0\n","\n","    p0=[A0,mu0,sigma0,C0]\n","\n","    popt,pcov=curve_fit(gaussian, x_fit, y_fit, p0=p0, maxfev=20000)\n","    A,mu,sigma,C=popt\n","\n","    beam_hpbw=hpbw(sigma)\n","    unc=hpbw_err(pcov)\n","\n","    x_c=np.linspace(deg_start, deg_stop, 500)\n","    y_c=gaussian(x_c, *popt)\n","    return {\"pol\":pol, \"az_g\":az_g, \"p2p\":p2p, \"x_c\":x_c, \"y_c\":y_c,\"HPBW\":beam_hpbw, \"uncertainty\":unc, \"center\":mu}"],"metadata":{"id":"67fJRH7UMYfc","executionInfo":{"status":"ok","timestamp":1776282740398,"user_tz":-60,"elapsed":11,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":151,"outputs":[]},{"cell_type":"code","source":["def normalize_el(r):\n","    r_norm=r.copy()\n","\n","    r_norm[\"p2p_norm\"]=normalize(r[\"p2p\"])\n","    r_norm[\"y_c_norm\"]=normalize(r[\"y_c\"])\n","    r_norm[\"az_unc\"]=np.full_like(r[\"az_g\"], deg_error, dtype=float)\n","\n","    return r_norm"],"metadata":{"id":"vDkIhTT5Tz64","executionInfo":{"status":"ok","timestamp":1776282741026,"user_tz":-60,"elapsed":4,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":152,"outputs":[]},{"cell_type":"code","source":["for fname in fits_files2[0:]:\n","\n","    left=normalize_el(fit_pol_el(fname, \"LEFT_POL\"))\n","    right=normalize_el(fit_pol_el(fname, \"RIGHT_POL\"))\n","\n","    plt.figure(figsize=(12, 6))\n","\n","    fit_l,=plt.plot(left[\"x_c\"], left[\"y_c_norm\"], \"-\", lw=2,\n","                    label=f\"Left Polarization Gaussian fit (HPBW = {left['HPBW']:.2f} $\\pm$ {left['uncertainty']:.2f}°)\")\n","\n","    fit_r,=plt.plot(right[\"x_c\"], right[\"y_c_norm\"], \"--\", lw=2,\n","                    label=f\"Right Polarization Gaussian fit (HPBW = {right['HPBW']:.2f} $\\pm$ {right['uncertainty']:.2f}°)\")\n","\n","    err_l=plt.errorbar(left[\"az_g\"], left[\"p2p_norm\"], xerr=left[\"az_unc\"],fmt=\"o\", ms=5, capsize=3, elinewidth=1, label=\"Left Polarization data\")\n","    err_r=plt.errorbar(right[\"az_g\"], right[\"p2p_norm\"], xerr=right[\"az_unc\"],fmt=\"s\", ms=5, capsize=3, elinewidth=1, label=\"Right Polarization data\")\n","\n","    plt.title(\"Elevation Beam Pattern with Gaussian Fit\\n\",fontsize=19)\n","    plt.suptitle(f\"{name(fname)}\",  fontsize=16)\n","    plt.xlabel(\"Elevation offset (deg)\",fontsize=15)\n","    plt.ylabel(\"Normalized peak-to-peak amplitude\", fontsize=15)\n","    plt.ylim(-0.05, 1.30)\n","    plt.grid(alpha=0.3)\n","\n","    handles=[fit_l, fit_r, err_l, err_r]\n","\n","    labels=[f\"Left Polarization Gaussian fit (HPBW = {left['HPBW']:.1f} $\\pm$ {left['uncertainty']:.1f}°)\",\n","            f\"Right Polarization Gaussian fit (HPBW = {right['HPBW']:.1f} $\\pm$ {right['uncertainty']:.1f}°)\",\n","            \"Left Polarization data\", \"Right Polarization data\"]\n","    plt.legend(handles, labels, frameon=True)\n","    plt.tight_layout()\n","    plt.show()\n","\n","    print(f\"Left Polarization Center = {left['center']:.3f} deg\\n\"\n","                f\"Right Polarization Center = {right['center']:.3f} deg\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"wlGEzP1sUCEa","executionInfo":{"status":"ok","timestamp":1776285692810,"user_tz":-60,"elapsed":4482,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"ab602dc1-f12a-4681-95fd-6649bab3ba70"},"execution_count":154,"outputs":[{"output_type":"stream","name":"stderr","text":["<>:9: SyntaxWarning: invalid escape sequence '\\p'\n","<>:12: SyntaxWarning: invalid escape sequence '\\p'\n","<>:26: SyntaxWarning: invalid escape sequence '\\p'\n","<>:27: SyntaxWarning: invalid escape sequence '\\p'\n","<>:9: SyntaxWarning: invalid escape sequence '\\p'\n","<>:12: SyntaxWarning: invalid escape sequence '\\p'\n","<>:26: SyntaxWarning: invalid escape sequence '\\p'\n","<>:27: SyntaxWarning: invalid escape sequence '\\p'\n","/tmp/ipykernel_2576/1289093703.py:9: SyntaxWarning: invalid escape sequence '\\p'\n","  label=f\"Left Polarization Gaussian fit (HPBW = {left['HPBW']:.2f} $\\pm$ {left['uncertainty']:.2f}°)\")\n","/tmp/ipykernel_2576/1289093703.py:12: SyntaxWarning: invalid escape sequence '\\p'\n","  label=f\"Right Polarization Gaussian fit (HPBW = {