\"\n","s11=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-170631_SPECTRUM-PROJ01-GAL_11#_01#.fits\"\n","s12=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-170756_SPECTRUM-PROJ01-GAL_12#_01#.fits\"\n","s13=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-170923_SPECTRUM-PROJ01-GAL_13#_01#.fits\"\n","s14=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-171045_SPECTRUM-PROJ01-GAL_14#_01#.fits\"\n","s15=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-171439_SPECTRUM-PROJ01-GAL_15#_01#.fits\"\n","s16=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-171624_SPECTRUM-PROJ01-GAL_16#_01#.fits\"\n","s17=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-171749_SPECTRUM-PROJ01-GAL_17#_01#.fits\"\n","s18=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-172121_SPECTRUM-PROJ01-GAL_18#_01#.fits\"\n","s19=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-172258_SPECTRUM-PROJ01-GAL_19#_01#.fits\"\n","s20=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-172426_SPECTRUM-PROJ01-GAL_20#_01#.fits\"\n","s21=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-172716_SPECTRUM-PROJ01-GAL_21#_01#.fits\"\n","s22=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-172847_SPECTRUM-PROJ01-GAL_22#_01#.fits\"\n","s23=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-173144_SPECTRUM-PROJ01-GAL_23#_01#.fits\"\n","s24=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-173302_SPECTRUM-PROJ01-GAL_24#_01#.fits\"\n","files = [s1,s2,s3,s4,s5,s6,s7,s8,s9,s10,s11,s12,s13,s14,s15,s16,s17,s18,s19,s20,s21,s22,s23,s24]"],"metadata":{"id":"bkknRd2RB85P","executionInfo":{"status":"ok","timestamp":1776457057331,"user_tz":-60,"elapsed":1,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":2,"outputs":[]},{"cell_type":"code","source":["from astropy.coordinates import SkyCoord\n","import astropy.units as u\n","\n","RA_set = [\n","    (1+31/60.+0.4/3600),\n","    (1+52/60.+22.3/3600),\n","    (1+52/60.+21.6/3600),\n","    (1+52/60.+22.4/3600),\n","    (1+52/60.+20.9/3600),\n","    (1+52/60.+21.7/3600),\n","    (1+27/60.+31.8/3600),\n","    (1+27/60.+32.1/3600),\n","    (1+27/60.+32.6/3600),\n","    (1+27/60.+33.0/3600),\n","    (3+46/60.+38.3/3600),\n","    (3+46/60.+34.0/3600),\n","    (3+46/60.+36.9/3600),\n","    (3+46/60.+36.8/3600),\n","    (1+52/60.+22.8/3600),\n","    (1+52/60.+21.5/3600),\n","    (1+52/60.+22.5/3600),\n","    (3+7/60.+22.0/3600),\n","    (3+7/60.+20.7/3600),\n","    (3+7/60.+19.8/3600),\n","    (3+7/60.+19.8/3600),\n","    (3+7/60.+20.6/3600),\n","    (4+4/60.+33.8/3600),\n","    (4+4/60.+32.9/3600),\n","]\n","\n","DEC_set = [\n","    52+8/60.+8.0/3600,\n","    62+2/60.+32.7/3600,\n","    62+2/60.+13.5/3600,\n","    62+2/60.+19.2/3600,\n","    62+1/60.+48.9/3600,\n","    62+2/60.+33.6/3600,\n","    42+22/60.+27.7/3600,\n","    42+22/60.+33.3/3600,\n","    42+22/60.+44.8/3600,\n","    42+22/60.+51.5/3600,\n","    80+22/60.+36.2/3600,\n","    80+22/60.+44.3/3600,\n","    80+22/60.+41.6/3600,\n","    80+22/60.+37.2/3600,\n","    62+1/60.+45.3/3600,\n","    62+2/60.+1.6/3600,\n","    62+1/60.+49.2/3600,\n","    58+17/60.+57.4/3600,\n","    58+17/60.+53.8/3600,\n","    58+17/60.+45.5/3600,\n","    58+17/60.+49.4/3600,\n","    58+17/60.+56.3/3600,\n","    52+25/60.+11.7/3600,\n","    52+25/60.+13.3/3600,\n","]\n","\n","l = []\n","b = []\n","\n","\n","\n","for i in range(24):\n","    c_icrs = SkyCoord(ra=RA_set[i]*u.hourangle, dec=DEC_set[i]*u.degree, frame='icrs')\n","    l.append(c_icrs.galactic.l.degree)\n","    b.append(c_icrs.galactic.b.degree)\n","    print(f\"file{i+1}: l={c_icrs.galactic.l.degree:.3f}°, b={c_icrs.galactic.b.degree:.3f}°\")\n","    plt.plot(c_icrs.galactic.l.degree, c_icrs.galactic.b.degree, \"ro\")\n","\n","\n","plt.xlabel(\"Galactic longitude / deg\")\n","plt.ylabel(\"Galactic latitude / deg\")\n","\n","plt.axhline(y=0, color='b', linestyle='--',label='Galactic plane (b=0°)')\n","plt.fill_between([0, 360], -5, 5, alpha=0.4,label='Milky Way band (|b| < 5°)')# Milky Way band (|b| < 5°)\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":857},"executionInfo":{"status":"ok","timestamp":1776457058067,"user_tz":-60,"elapsed":735,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"583aeb06-6e4b-406b-a20d-790c63bd42c9","id":"f6DzQzXAarhY"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["file1: l=129.084°, b=-10.263°\n","file2: l=130.008°, b=0.011°\n","file3: l=130.008°, b=0.005°\n","file4: l=130.009°, b=0.007°\n","file5: l=130.008°, b=-0.002°\n","file6: l=130.007°, b=0.011°\n","file7: l=130.014°, b=-20.001°\n","file8: l=130.015°, b=-19.999°\n","file9: l=130.016°, b=-19.995°\n","file10: l=130.017°, b=-19.993°\n","file11: l=130.005°, b=20.010°\n","file12: l=130.001°, b=20.010°\n","file13: l=130.003°, b=20.011°\n","file14: l=130.004°, b=20.010°\n","file15: l=130.012°, b=-0.002°\n","file16: l=130.008°, b=0.002°\n","file17: l=130.011°, b=-0.001°\n","file18: l=140.012°, b=0.009°\n","file19: l=140.010°, b=0.006°\n","file20: l=140.010°, b=0.004°\n","file21: l=140.009°, b=0.004°\n","file22: l=140.010°, b=0.007°\n","file23: l=150.011°, b=0.009°\n","file24: l=150.009°, b=0.008°\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":[],"metadata":{"id":"rACFRJphb4pR","executionInfo":{"status":"ok","timestamp":1776457058070,"user_tz":-60,"elapsed":2,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":3,"outputs":[]},{"cell_type":"code","source":["from astropy.time import Time\n","from astropy.coordinates import SkyCoord, EarthLocation, Galactic\n","\n","UCLO = EarthLocation.from_geodetic(lon=-0.25*u.deg, lat=52.0*u.deg, height=100*u.m)\n","\n","apex = SkyCoord(l=57.0*u.deg, b=22.0*u.deg, frame=Galactic).icrs\n","solar_motion_speed = 20.0 * u.km/u.s # Standard solar motion speed\n","\n","vcorr_per_file = []\n","for i in range(24):\n","    sc = SkyCoord(ra=RA_set[i]*u.hourangle, dec=DEC_set[i]*u.deg)\n","    obs_time = Time('2026-2-05')\n","\n","\n","    helio_corr = sc.radial_velocity_correction('heliocentric', obstime=obs_time, location=UCLO)\n","\n","\n","    ra_rad = sc.ra.to(u.rad).value\n","    dec_rad = sc.dec.to(u.rad).value\n","    apex_ra_rad = apex.ra.to(u.rad).value\n","    apex_dec_rad = apex.dec.to(u.rad).value\n","\n","    cos_angle = (np.sin(dec_rad) * np.sin(apex_dec_rad) + np.cos(dec_rad) * np.cos(apex_dec_rad) * np.cos(ra_rad - apex_ra_rad))    # Cosine of the angle between the source and the solar apex\n","    v_sun_proj = solar_motion_speed * cos_angle\n","\n","\n","    # Total LSRK correction\n","    total_corr  = helio_corr + v_sun_proj\n","    vcorr_per_file.append(total_corr.to(u.km/u.s).value)\n","    print(f\"file{i+1}:\")\n","    print(f\" helio corr = {helio_corr.to(u.km/u.s).value:.3f} km/s, solar corr = {v_sun_proj.to(u.km/u.s).value:.3f} km/s, total vcorr (Vcorr) = {total_corr.to(u.km/u.s).value:.3f} km/s\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776457070843,"user_tz":-60,"elapsed":12773,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"f836378b-dc89-4fb2-9fee-f845c1fd5ccc","id":"MV7Ommlqyema"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["file1:\n"," helio corr = -23.600 km/s, solar corr = 4.278 km/s, total vcorr (Vcorr) = -19.321 km/s\n","file2:\n"," helio corr = -20.801 km/s, solar corr = 5.421 km/s, total vcorr (Vcorr) = -15.380 km/s\n","file3:\n"," helio corr = -20.802 km/s, solar corr = 5.420 km/s, total vcorr (Vcorr) = -15.382 km/s\n","file4:\n"," helio corr = -20.802 km/s, solar corr = 5.420 km/s, total vcorr (Vcorr) = -15.382 km/s\n","file5:\n"," helio corr = -20.805 km/s, solar corr = 5.419 km/s, total vcorr (Vcorr) = -15.386 km/s\n","file6:\n"," helio corr = -20.800 km/s, solar corr = 5.421 km/s, total vcorr (Vcorr) = -15.379 km/s\n","file7:\n"," helio corr = -25.932 km/s, solar corr = 2.528 km/s, total vcorr (Vcorr) = -23.404 km/s\n","file8:\n"," helio corr = -25.932 km/s, solar corr = 2.528 km/s, total vcorr (Vcorr) = -23.404 km/s\n","file9:\n"," helio corr = -25.931 km/s, solar corr = 2.528 km/s, total vcorr (Vcorr) = -23.403 km/s\n","file10:\n"," helio corr = -25.931 km/s, solar corr = 2.528 km/s, total vcorr (Vcorr) = -23.403 km/s\n","file11:\n"," helio corr = -13.163 km/s, solar corr = 7.657 km/s, total vcorr (Vcorr) = -5.507 km/s\n","file12:\n"," helio corr = -13.163 km/s, solar corr = 7.658 km/s, total vcorr (Vcorr) = -5.505 km/s\n","file13:\n"," helio corr = -13.163 km/s, solar corr = 7.657 km/s, total vcorr (Vcorr) = -5.506 km/s\n","file14:\n"," helio corr = -13.163 km/s, solar corr = 7.657 km/s, total vcorr (Vcorr) = -5.507 km/s\n","file15:\n"," helio corr = -20.805 km/s, solar corr = 5.418 km/s, total vcorr (Vcorr) = -15.388 km/s\n","file16:\n"," helio corr = -20.803 km/s, solar corr = 5.419 km/s, total vcorr (Vcorr) = -15.384 km/s\n","file17:\n"," helio corr = -20.805 km/s, solar corr = 5.418 km/s, total vcorr (Vcorr) = -15.387 km/s\n","file18:\n"," helio corr = -22.596 km/s, solar corr = 2.257 km/s, total vcorr (Vcorr) = -20.339 km/s\n","file19:\n"," helio corr = -22.596 km/s, solar corr = 2.257 km/s, total vcorr (Vcorr) = -20.339 km/s\n","file20:\n"," helio corr = -22.597 km/s, solar corr = 2.257 km/s, total vcorr (Vcorr) = -20.340 km/s\n","file21:\n"," helio corr = -22.597 km/s, solar corr = 2.258 km/s, total vcorr (Vcorr) = -20.339 km/s\n","file22:\n"," helio corr = -22.596 km/s, solar corr = 2.258 km/s, total vcorr (Vcorr) = -20.338 km/s\n","file23:\n"," helio corr = -23.703 km/s, solar corr = -0.973 km/s, total vcorr (Vcorr) = -24.676 km/s\n","file24:\n"," helio corr = -23.703 km/s, solar corr = -0.972 km/s, total vcorr (Vcorr) = -24.675 km/s\n"]}]},{"cell_type":"code","source":["off_files={\"l=130°\": files[2:14]}"],"metadata":{"id":"t_LMYZVQNm2s","executionInfo":{"status":"ok","timestamp":1776457071002,"user_tz":-60,"elapsed":163,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":5,"outputs":[]},{"cell_type":"code","source":["def read_spec(filepath):\n","    with fits.open(filepath, ignore_missing_end=True) as h:\n","        d,hdr=h[1].data,h[1].header\n","        bf=hdr[\"BASEFREQ\"]\n","        bw=hdr[\"BANDWID\"]\n","        freq=(bf+(np.arange(1024)+0.5)*(bw/1024))/1e9 # GHz\n","\n","        status=np.array([s.strip().lower() for s in d.field(\"STATUS\")])\n","        mask=status==\"on\" #for all ons\n","        l=d.field(7)[mask].astype(float)\n","        r=d.field(8)[mask].astype(float)\n","    l_mean=np.mean(l,axis=0)\n","    r_mean=np.mean(r,axis=0)\n","    l_err=np.std(l,axis=0,ddof=1)/np.sqrt(l.shape[0])\n","    r_err=np.std(r,axis=0,ddof=1)/np.sqrt(r.shape[0])\n","\n","    return freq,l_mean,r_mean,l_err,r_err"],"metadata":{"id":"WqYq5rH4NF1q","executionInfo":{"status":"ok","timestamp":1776457071012,"user_tz":-60,"elapsed":5,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":6,"outputs":[]},{"cell_type":"code","source":["arm_ranges={\"l=130°\":{\"Outer\":(-92.8,-75.2),\"Perseus\":(-49.5,-40.2)},\n","            \"l=140°\":{\"Outer\":(-75.2,-55.7),\"Perseus\":(-40.2,-33.0)},\n","            \"l=150°\":{\"Outer\":(-55.7,-6.2),\"Perseus\":(-34.0,-32.0)},}"],"metadata":{"id":"ynId6xmVPlDH","executionInfo":{"status":"ok","timestamp":1776457071017,"user_tz":-60,"elapsed":7,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":7,"outputs":[]},{"cell_type":"code","source":["outer_l=[100.5,136.0,136.5,148.0,148.5,180.0]\n","outer_v=[-92.8,-75.2,-75.2,-55.7,-55.7,-6.2]\n","perseus_l=[109.0,142.5,143.0,148.0,148.5,155.5]\n","perseus_v=[-49.5,-40.2,-40.2,-33.0,-34.0,-32.0]\n","\n","arm_ref={}\n","for label in off_files:\n","    l_val=float(label.replace(\"l=\",\"\").replace(\"°\",\"\"))\n","    arm_ref[label]={\"Outer\":np.interp(l_val,outer_l,outer_v), \"Perseus\":np.interp(l_val,perseus_l,perseus_v)}\n","print(arm_ref)\n","a_c={\"Perseus\": \"#F97F5F\", \"Outer\": \"#E9687A\"}"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"IobMWpGpM_Wi","executionInfo":{"status":"ok","timestamp":1776457071081,"user_tz":-60,"elapsed":62,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"9ace33e1-9f15-471f-912c-b28f466dafd7"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["{'l=130°': {'Outer': np.float64(-78.17464788732394), 'Perseus': np.float64(-43.670149253731346)}}\n"]}]},{"cell_type":"code","source":["off_all=files[6:10]+files[10:14]  # b=-20 and b=+20\n","\n","f0=1.42040575177 #GHz\n","c=299792.458\n","plt.figure(figsize=(10,4))\n","for f in off_all:\n","    freq,sl,sr,_,_=read_spec(f)\n","    vc=vcorr_per_file[files.index(f)]\n","    vel=c*(f0-freq)/f0 +vc\n","\n","    m=(vel>-270)&(vel<40)\n","    plt.plot(vel[m],sr[m]/np.nanmax(sr[m]),alpha=0.7,label=f\"l={l[files.index(f)]:.1f}° b={b[files.index(f)]:.1f}°\")\n","for arm,(v_lo,v_hi) in arm_ranges[label].items():\n","    plt.axvspan(v_lo,v_hi,alpha=0.15,color=a_c[arm],label=f\"{arm}\")\n","    plt.text((v_lo+v_hi)/2,0.95,arm,transform=plt.gca().get_xaxis_transform(),va='top',ha='center',fontsize=9,color=a_c[arm])\n","plt.xlabel(r\"$v_\\mathrm{LSR}$ (km s$^{-1}$)\")\n","plt.ylabel(\"Normalised intensity\")\n","plt.xlim(-200,-10)\n","plt.title(\"Structured HI emission in OFF reference fields (Right polarization)\")\n","plt.legend(fontsize=8)\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":529},"id":"vsjDPu8NM6Jr","executionInfo":{"status":"ok","timestamp":1776457122763,"