{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"mount_file_id":"1w_o2nTWZeXXs653babwZvPogW0svRAM1","authorship_tag":"ABX9TyMkwNipivEoSuS1ULZqfOte"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["from astropy.io import fits\n","from astropy.coordinates import SkyCoord, EarthLocation, Galactic\n","from astropy.time import Time\n","import astropy.units as u\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from scipy.optimize import curve_fit\n","import re"],"metadata":{"id":"rYZ2Nzbfshuk","executionInfo":{"status":"ok","timestamp":1776592548250,"user_tz":-60,"elapsed":2342,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":1,"outputs":[]},{"cell_type":"code","source":[],"metadata":{"id":"-JVTUErn8cvV","executionInfo":{"status":"ok","timestamp":1776592548262,"user_tz":-60,"elapsed":9,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":1,"outputs":[]},{"cell_type":"code","source":["s1 =\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-163250_SPECTRUM-PROJ01-GAL_01#_01#.fits\"\n","s2 =\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-163915_SPECTRUM-PROJ01-GAL_02#_01#.fits\"\n","s3 =\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-164116_SPECTRUM-PROJ01-GAL_03#_01#.fits\"\n","s4 =\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-164440_SPECTRUM-PROJ01-GAL_04#_01#.fits\"\n","s5 =\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-164606_SPECTRUM-PROJ01-GAL_05#_01#.fits\"\n","s6 =\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-164906_SPECTRUM-PROJ01-GAL_06#_01#.fits\"\n","s7 =\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-165453_SPECTRUM-PROJ01-GAL_07#_01#.fits\"\n","s8 =\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-165621_SPECTRUM-PROJ01-GAL_08#_01#.fits\"\n","s9 =\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-165828_SPECTRUM-PROJ01-GAL_09#_01#.fits\"\n","s10=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-170158_SPECTRUM-PROJ01-GAL_10#_01#.fits\"\n","s11=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-170631_SPECTRUM-PROJ01-GAL_11#_01#.fits\"\n","s12=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-170756_SPECTRUM-PROJ01-GAL_12#_01#.fits\"\n","s13=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-170923_SPECTRUM-PROJ01-GAL_13#_01#.fits\"\n","s14=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-171045_SPECTRUM-PROJ01-GAL_14#_01#.fits\"\n","s15=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-171439_SPECTRUM-PROJ01-GAL_15#_01#.fits\"\n","s16=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-171624_SPECTRUM-PROJ01-GAL_16#_01#.fits\"\n","s17=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-171749_SPECTRUM-PROJ01-GAL_17#_01#.fits\"\n","s18=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-172121_SPECTRUM-PROJ01-GAL_18#_01#.fits\"\n","s19=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-172258_SPECTRUM-PROJ01-GAL_19#_01#.fits\"\n","s20=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-172426_SPECTRUM-PROJ01-GAL_20#_01#.fits\"\n","s21=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-172716_SPECTRUM-PROJ01-GAL_21#_01#.fits\"\n","s22=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-172847_SPECTRUM-PROJ01-GAL_22#_01#.fits\"\n","s23=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-173144_SPECTRUM-PROJ01-GAL_23#_01#.fits\"\n","s24=\"/content/drive/MyDrive/Colab Notebooks/RT/20260205/FITS/20260205-173302_SPECTRUM-PROJ01-GAL_24#_01#.fits\"\n","files = [s1,s2,s3,s4,s5,s6,s7,s8,s9,s10,s11,s12,s13,s14,s15,s16,s17,s18,s19,s20,s21,s22,s23,s24]"],"metadata":{"id":"bkknRd2RB85P","executionInfo":{"status":"ok","timestamp":1776592548277,"user_tz":-60,"elapsed":9,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}}},"execution_count":2,"outputs":[]},{"cell_type":"code","source":["from astropy.coordinates import SkyCoord\n","import astropy.units as u\n","\n","RA_set = [\n","    (1+31/60.+0.4/3600),\n","    (1+52/60.+22.3/3600),\n","    (1+52/60.+21.6/3600),\n","    (1+52/60.+22.4/3600),\n","    (1+52/60.+20.9/3600),\n","    (1+52/60.+21.7/3600),\n","    (1+27/60.+31.8/3600),\n","    (1+27/60.+32.1/3600),\n","    (1+27/60.+32.6/3600),\n","    (1+27/60.+33.0/3600),\n","    (3+46/60.+38.3/3600),\n","    (3+46/60.+34.0/3600),\n","    (3+46/60.+36.9/3600),\n","    (3+46/60.+36.8/3600),\n","    (1+52/60.+22.8/3600),\n","    (1+52/60.+21.5/3600),\n","    (1+52/60.+22.5/3600),\n","    (3+7/60.+22.0/3600),\n","    (3+7/60.+20.7/3600),\n","    (3+7/60.+19.8/3600),\n","    (3+7/60.+19.8/3600),\n","    (3+7/60.+20.6/3600),\n","    (4+4/60.+33.8/3600),\n","    (4+4/60.+32.9/3600),\n","]\n","\n","DEC_set = [\n","    52+8/60.+8.0/3600,\n","    62+2/60.+32.7/3600,\n","    62+2/60.+13.5/3600,\n","    62+2/60.+19.2/3600,\n","    62+1/60.+48.9/3600,\n","    62+2/60.+33.6/3600,\n","    42+22/60.+27.7/3600,\n","    42+22/60.+33.3/3600,\n","    42+22/60.+44.8/3600,\n","    42+22/60.+51.5/3600,\n","    80+22/60.+36.2/3600,\n","    80+22/60.+44.3/3600,\n","    80+22/60.+41.6/3600,\n","    80+22/60.+37.2/3600,\n","    62+1/60.+45.3/3600,\n","    62+2/60.+1.6/3600,\n","    62+1/60.+49.2/3600,\n","    58+17/60.+57.4/3600,\n","    58+17/60.+53.8/3600,\n","    58+17/60.+45.5/3600,\n","    58+17/60.+49.4/3600,\n","    58+17/60.+56.3/3600,\n","    52+25/60.+11.7/3600,\n","    52+25/60.+13.3/3600,\n","]\n","\n","l = []\n","b = []\n","\n","\n","\n","for i in range(24):\n","    c_icrs = SkyCoord(ra=RA_set[i]*u.hourangle, dec=DEC_set[i]*u.degree, frame='icrs')\n","    l.append(c_icrs.galactic.l.degree)\n","    b.append(c_icrs.galactic.b.degree)\n","    print(f\"file{i+1}: l={c_icrs.galactic.l.degree:.3f}°, b={c_icrs.galactic.b.degree:.3f}°\")\n","    plt.plot(c_icrs.galactic.l.degree, c_icrs.galactic.b.degree, \"ro\")\n","\n","\n","plt.xlabel(\"Galactic longitude / deg\")\n","plt.ylabel(\"Galactic latitude / deg\")\n","\n","plt.axhline(y=0, color='b', linestyle='--',label='Galactic plane (b=0°)')\n","plt.fill_between([0, 360], -5, 5, alpha=0.4,label='Milky Way band (|b| < 5°)')# Milky Way band (|b| < 5°)\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":857},"executionInfo":{"status":"ok","timestamp":1776592561405,"user_tz":-60,"elapsed":1129,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"139028ef-6620-47cc-ccc4-0e74d4020d06","id":"f6DzQzXAarhY"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["file1: l=129.084°, b=-10.263°\n","file2: l=130.008°, b=0.011°\n","file3: l=130.008°, b=0.005°\n","file4: l=130.009°, b=0.007°\n","file5: l=130.008°, b=-0.002°\n","file6: l=130.007°, b=0.011°\n","file7: l=130.014°, b=-20.001°\n","file8: l=130.015°, b=-19.999°\n","file9: l=130.016°, b=-19.995°\n","file10: l=130.017°, b=-19.993°\n","file11: l=130.005°, b=20.010°\n","file12: l=130.001°, b=20.010°\n","file13: l=130.003°, b=20.011°\n","file14: l=130.004°, b=20.010°\n","file15: l=130.012°, b=-0.002°\n","file16: l=130.008°, b=0.002°\n","file17: l=130.011°, b=-0.001°\n","file18: l=140.012°, b=0.009°\n","file19: l=140.010°, b=0.006°\n","file20: l=140.010°, b=0.004°\n","file21: l=140.009°, b=0.004°\n","file22: l=140.010°, b=0.007°\n","file23: l=150.011°, b=0.009°\n","file24: l=150.009°, b=0.008°\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["from astropy.time import Time\n","from astropy.coordinates import SkyCoord, EarthLocation, Galactic\n","\n","UCLO = EarthLocation.from_geodetic(lon=-0.25*u.deg, lat=52.0*u.deg, height=100*u.m)\n","\n","\n","apex = SkyCoord(l=57.0*u.deg, b=22.0*u.deg, frame=Galactic).icrs\n","solar_motion_speed = 20.0 * u.km/u.s # Standard solar motion speed\n","\n","vcorr_per_file = {}\n","for i in range(24):\n","    sc = SkyCoord(ra=RA_set[i]*u.hourangle, dec=DEC_set[i]*u.deg)\n","    obs_time = Time('2026-2-05')\n","\n","\n","    helio_corr = sc.radial_velocity_correction('heliocentric', obstime=obs_time, location=UCLO)\n","\n","\n","    ra_rad = sc.ra.to(u.rad).value\n","    dec_rad = sc.dec.to(u.rad).value\n","    apex_ra_rad = apex.ra.to(u.rad).value\n","    apex_dec_rad = apex.dec.to(u.rad).value\n","\n","    cos_angle = (np.sin(dec_rad) * np.sin(apex_dec_rad) + np.cos(dec_rad) * np.cos(apex_dec_rad) * np.cos(ra_rad - apex_ra_rad))    # Cosine of the angle between the source and the solar apex\n","    v_sun_proj = solar_motion_speed * cos_angle\n","\n","\n","    # Total LSRK correction\n","    total_corr  = helio_corr + v_sun_proj\n","    vcorr_per_file[files[i]] = total_corr.to(u.km/u.s).value\n","\n","    print(f\"file{i+1}:\")\n","    print(f\" helio corr = {helio_corr.to(u.km/u.s).value:.3f} km/s, solar corr = {v_sun_proj.to(u.km/u.s).value:.3f} km/s, total vcorr (Vcorr) = {total_corr.to(u.km/u.s).value:.3f} km/s\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776592580900,"user_tz":-60,"elapsed":16331,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"3b0bd34c-c12d-43a9-aad3-b77ed64a7340","id":"MV7Ommlqyema"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["file1:\n"," helio corr = -23.600 km/s, solar corr = 4.278 km/s, total vcorr (Vcorr) = -19.321 km/s\n","file2:\n"," helio corr = -20.801 km/s, solar corr = 5.421 km/s, total vcorr (Vcorr) = -15.380 km/s\n","file3:\n"," helio corr = -20.802 km/s, solar corr = 5.420 km/s, total vcorr (Vcorr) = -15.382 km/s\n","file4:\n"," helio corr = -20.802 km/s, solar corr = 5.420 km/s, total vcorr (Vcorr) = -15.382 km/s\n","file5:\n"," helio corr = -20.805 km/s, solar corr = 5.419 km/s, total vcorr (Vcorr) = -15.386 km/s\n","file6:\n"," helio corr = -20.800 km/s, solar corr = 5.421 km/s, total vcorr (Vcorr) = -15.379 km/s\n","file7:\n"," helio corr = -25.932 km/s, solar corr = 2.528 km/s, total vcorr (Vcorr) = -23.404 km/s\n","file8:\n"," helio corr = -25.932 km/s, solar corr = 2.528 km/s, total vcorr (Vcorr) = -23.404 km/s\n","file9:\n"," helio corr = -25.931 km/s, solar corr = 2.528 km/s, total vcorr (Vcorr) = -23.403 km/s\n","file10:\n"," helio corr = -25.931 km/s, solar corr = 2.528 km/s, total vcorr (Vcorr) = -23.403 km/s\n","file11:\n"," helio corr = -13.163 km/s, solar corr = 7.657 km/s, total vcorr (Vcorr) = -5.507 km/s\n","file12:\n"," helio corr = -13.163 km/s, solar corr = 7.658 km/s, total vcorr (Vcorr) = -5.505 km/s\n","file13:\n"," helio corr = -13.163 km/s, solar corr = 7.657 km/s, total vcorr (Vcorr) = -5.506 km/s\n","file14:\n"," helio corr = -13.163 km/s, solar corr = 7.657 km/s, total vcorr (Vcorr) = -5.507 km/s\n","file15:\n"," helio corr = -20.805 km/s, solar corr = 5.418 km/s, total vcorr (Vcorr) = -15.388 km/s\n","file16:\n"," helio corr = -20.803 km/s, solar corr = 5.419 km/s, total vcorr (Vcorr) = -15.384 km/s\n","file17:\n"," helio corr = -20.805 km/s, solar corr = 5.418 km/s, total vcorr (Vcorr) = -15.387 km/s\n","file18:\n"," helio corr = -22.596 km/s, solar corr = 2.257 km/s, total vcorr (Vcorr) = -20.339 km/s\n","file19:\n"," helio corr = -22.596 km/s, solar corr = 2.257 km/s, total vcorr (Vcorr) = -20.339 km/s\n","file20:\n"," helio corr = -22.597 km/s, solar corr = 2.257 km/s, total vcorr (Vcorr) = -20.340 km/s\n","file21:\n"," helio corr = -22.597 km/s, solar corr = 2.258 km/s, total vcorr (Vcorr) = -20.339 km/s\n","file22:\n"," helio corr = -22.596 km/s, solar corr = 2.258 km/s, total vcorr (Vcorr) = -20.338 km/s\n","file23:\n"," helio corr = -23.703 km/s, solar corr = -0.973 km/s, total vcorr (Vcorr) = -24.676 km/s\n","file24:\n"," helio corr = -23.703 km/s, solar corr = -0.972 km/s, total vcorr (Vcorr) = -24.675 km/s\n"]}]},{"cell_type":"markdown","source":[],"metadata":{"id":"I8iriQFRf8Ir"}},{"cell_type":"code","source":["sc_gal = SkyCoord(l=130*u.deg, b=0*u.deg, frame=Galactic)\n","print(sc_gal.icrs.ra, sc_gal.icrs.dec)\n","print(SkyCoord(ra=RA_set[1]*u.hourangle, dec=DEC_set[1]*u.deg).ra,\n","      SkyCoord(ra=RA_set[1]*u.hourangle, dec=DEC_set[1]*u.deg).dec)"],"metadata":{"id":"DCmZGYRVEiTf","executionInfo":{"status":"ok","timestamp":1776593189286,"user_tz":-60,"elapsed":72,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"13fc688b-a2fe-41cc-d957-9b27f0a08a14"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["28d04m17.38840559s 62d02m01.83444187s\n","28d05m34.5s 62d02m32.7s\n"]}]},{"cell_type":"code","source":["on_groups={\"l=130°\": files[1:6]+files[14:17],\"l=140°\": files[17:22],\"l=150°\": files[22:24]}\n","#b=20 as OFF\n","off_files=files[10:14]\n","file_labels={f:f\"s{i+1}\" for i,f in enumerate(files)}"],"metadata":{"id":"2A8AKU3Wf66o"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def read_spec(filepath):\n","    with fits.open(filepath, ignore_missing_end=True) as h:\n","        d,hdr=h[1].data,h[1].header\n","        bf=hdr[\"BASEFREQ\"]\n","        bw=hdr[\"BANDWID\"]\n","        freq=(bf+(np.arange(1024)+0.5)*(bw/1024))/1e9 # GHz\n","\n","        status=np.array([s.strip().lower() for s in d.field(\"STATUS\")])\n","        mask=status==\"on\" #for all ons\n","        l=d.field(7)[mask].astype(float)\n","        r=d.field(8)[mask].astype(float)\n","    l_mean=np.mean(l,axis=0)\n","    r_mean=np.mean(r,axis=0)\n","    l_err=np.std(l,axis=0,ddof=1)/np.sqrt(l.shape[0])\n","    r_err=np.std(r,axis=0,ddof=1)/np.sqrt(r.shape[0])\n","\n","    return freq,l_mean,r_mean,l_err,r_err"],"metadata":{"id":"mQYjjdMUhAG2"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["REMEMBER TO DOUBLE CHECK THE UNIT"],"metadata":{"id":"4Cz6palHSpu7"}},{"cell_type":"markdown","source":["USING LAB AS ESTIMATION"],"metadata":{"id":"W9h_xTUVk9ud"}},{"cell_type":"code","source":["\n","f0=1.42040575177 #GHz\n","c=299792.458\n","\n","\n","def gaussian(x,A,mu,sig):\n","    return A*np.exp(-0.5*((x-mu)/sig)**2)\n","lab_local_arm=-3.0\n","local_arm_results=[]\n","for f in off_files:\n","    freq,sl,sr,_,_=read_spec(f)\n","    vc=vcorr_per_file[f]\n","    vel=c*(f0-freq)/f0+vc\n","    m=(vel>-30)&(vel<15)\n","    v_win=vel[m]\n","    s_win=sr[m]\n","    peak_idx=np.nanargmax(s_win)\n","    p0=[s_win[peak_idx],v_win[peak_idx],3.0]\n","\n","    popt,_=curve_fit(gaussian,v_win[np.isfinite(s_win)],s_win[np.isfinite(s_win)],p0=p0)\n","    delta_v=lab_local_arm-popt[1]\n","    local_arm_results.append(delta_v)\n","    print(f\"{file_labels[f]}: peak={popt[1]:.2f} km/s delta v={delta_v:+.2f} km/s\")\n","\n","print(f\"Mean delta v ={np.mean(local_arm_results):.2f}±{np.std(local_arm_results):.2f} km/s\")"],"metadata":{"id":"TeohnjmHOpg5","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776532440913,"user_tz":-60,"elapsed":114,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"f28157f7-5c40-4e4f-8b30-5fad009da78f"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["s11: peak=-14.13 km/s delta v=+11.13 km/s\n","s12: peak=-13.97 km/s delta v=+10.97 km/s\n","s13: peak=-13.97 km/s delta v=+10.97 km/s\n","s14: peak=-14.07 km/s delta v=+11.07 km/s\n","Mean delta v =11.04±0.07 km/s\n"]},{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_6834/2729567977.py:19: OptimizeWarning: Covariance of the parameters could not be estimated\n","  popt,_=curve_fit(gaussian,v_win[np.isfinite(s_win)],s_win[np.isfinite(s_win)],p0=p0)\n"]}]},{"cell_type":"code","source":["print(total_corr)\n","print(total_corr.to(u.km/u.s))"],"metadata":{"id":"DtNWv5umB1fl","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776429888838,"user_tz":-60,"elapsed":3,"user":{"displayName":"Eilift Zhang","userId":"14663414634615931882"}},"outputId":"e8f2a2af-85c6-41e0-c751-8d11005182c3"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["-0.01425124574241041 AU / d\n","-24.67541687369257 km / s\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"Cq0lKr56HgbC"},"execution_count":null,"outputs":[]}]}